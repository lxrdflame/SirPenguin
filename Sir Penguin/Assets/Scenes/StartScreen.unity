  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TextUi
  uiText: {fileID: 423390749}
  UITextContainer: {fileID: 1107334603}
  GuideText:
  - Hey there! Welcome. To get started press R1 to shoot and R2 to scope further
    enemies. ("X" to proceed)
  - WOW you've learnt how to shoot! Now collect a pebble and deposite it into the
    cash box ahead. ("X" to Proceed)
  - Make sure to watch out for the Seagull because it will try steal one of your
    pebbles. Sprint and press "0" to belly side to avoid the Seagullslid
